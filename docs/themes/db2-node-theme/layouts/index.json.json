{{- $searchable := where .Site.Pages "Kind" "in" (slice "home" "page" "section") -}}
{{- $docs := slice -}}
{{- range $searchable -}}
  {{- $docs = $docs | append (dict
    "title" .Title
    "kind" .Kind
    "section" .Section
    "relPermalink" .RelPermalink
    "summary" (.Summary | plainify)
    "content" (.Plain | plainify)
  ) -}}
{{- end -}}
{{- $docs | jsonify -}}
